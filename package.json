{
  "name": "better-webclass",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:firefox": "vite build --watch --mode firefox",
    "build": "vite build",
    "build:firefox": "vite build --mode firefox",
    "build:all": "vite build && vite build --mode firefox",
    "pack": "cd dist && zip -r ../better-webclass-chrome.zip . && cd ../dist-firefox && zip -r ../better-webclass-firefox.zip .",
    "pack:chrome": "cd dist && zip -r ../better-webclass-chrome.zip .",
    "pack:firefox": "cd dist-firefox && zip -r ../better-webclass-firefox.zip .",
    "pack:source": "git archive HEAD -o better-webclass-source.zip",
    "release": "vite build && vite build --mode firefox && npm run pack && npm run pack:source",
    "type-check": "tsc --noEmit"
  },
  "overrides": {
    "tmp": "0.2.7",
    "shell-quote": "^1.8.4",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.320",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vite-plugin-web-extension": "^4.5.1"
  }
}
